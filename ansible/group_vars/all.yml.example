---
# Copy to ansible/group_vars/all.yml (gitignored) and customize.

# Base role
base_timezone: Africa/Nairobi
base_manage_firewall: true
base_install_fail2ban: true
base_enable_unattended_upgrades: true
base_apt_upgrade: dist
base_unattended_auto_reboot: false
base_set_timezone: true
base_ssh_port: "1773"
base_allowed_ssh_ports:
  - "1773"

base_manage_admin_user: true
base_require_admin_ssh_key: true
base_remove_ubuntu_user: true
base_admin_user: "{{ lookup('ansible.builtin.env', 'INFRA_ADMIN_USER') | default('openclaw', true) }}"
base_admin_password: "{{ lookup('ansible.builtin.env', 'INFRA_ADMIN_PASSWORD') | default('', true) }}"
base_admin_password_hash: "{{ lookup('ansible.builtin.env', 'INFRA_ADMIN_PASSWORD_HASH') | default('', true) }}"
base_admin_ssh_public_key: "{{ lookup('ansible.builtin.env', 'INFRA_ADMIN_SSH_PUBLIC_KEY') | default('', true) }}"
base_admin_ssh_public_keys: []
base_admin_groups: sudo
base_fqdn: "{{ lookup('ansible.builtin.env', 'INFRA_FQDN') | default('', true) }}"
base_host_ip: "{{ lookup('ansible.builtin.env', 'INFRA_HOST_IP') | default('', true) }}"
base_configure_motd: true

# Hardening role
hardening_enable_devsec: true
os_ignore_users:
  - ubuntu
  - "{{ base_admin_user }}"

ssh_server_password_login: false
ssh_server_ports:
  - "{{ base_ssh_port }}"
ssh_client_port: "{{ base_ssh_port }}"
ssh_permit_root_login: "no"
ssh_use_dns: false
ssh_max_auth_retries: 2
ssh_allow_tcp_forwarding: "no"
ssh_x11_forwarding: false
ssh_allow_users: "{{ base_admin_user }}"
ssh_print_motd: false
ssh_print_last_log: false
ssh_print_debian_banner: false

# Cloudflare role
cloudflare_enable: false
cloudflare_install_origin_ca_root: true
cloudflare_origin_ca_root_type: rsa

cloudflare_zone_id: "{{ lookup('ansible.builtin.env', 'CLOUDFLARE_ZONE_ID') | default('', true) }}"
cloudflare_zone_name: "{{ lookup('ansible.builtin.env', 'CLOUDFLARE_ZONE_NAME') | default('', true) }}"
cloudflare_email: "{{ lookup('ansible.builtin.env', 'CLOUDFLARE_EMAIL') | default('', true) }}"
cloudflare_global_api_key: "{{ lookup('ansible.builtin.env', 'CLOUDFLARE_GLOBAL_API_KEY') | default('', true) }}"
cloudflare_dns_api_token: "{{ lookup('ansible.builtin.env', 'CLOUDFLARE_DNS_API_TOKEN') | default('', true) }}"

cloudflare_manage_ssl_mode: false
cloudflare_ssl_mode: strict
cloudflare_manage_dns: false
cloudflare_dns_default_ttl: 1
cloudflare_dns_default_proxied: false
cloudflare_dns_records: []
# Example for Traefik hub + wildcard app routing:
# cloudflare_manage_dns: true
# cloudflare_manage_ssl_mode: true
# cloudflare_zone_name: akhenda.net
# cloudflare_zone_id: "YOUR_ZONE_ID"
# cloudflare_dns_records:
#   - record: hub
#     type: A
#     value: 185.185.80.175
#     proxied: true
#   - record: "*"
#     type: CNAME
#     value: hub.akhenda.net
#     proxied: true

# Traefik role
traefik_enable: false
traefik_install_docker: true
traefik_manage_user_group: true
traefik_admin_user: "{{ base_admin_user }}"
traefik_manage_firewall_rules: true
traefik_firewall_ports:
  - "80"
  - "443"

traefik_stack_root: /opt/traefik
traefik_image: traefik:v2.11
traefik_network_name: proxy

traefik_domain: ""
traefik_dashboard_enable: false
traefik_dashboard_host: "{{ ('traefik.' ~ traefik_domain) if (traefik_domain | length > 0) else '' }}"

traefik_use_origin_cert: false
traefik_origin_cert_content: ""
traefik_origin_key_content: ""

# Example for akhenda.net hub workflow:
# traefik_enable: true
# traefik_domain: akhenda.net
# traefik_dashboard_enable: true
# traefik_dashboard_host: traefik.akhenda.net
# traefik_use_origin_cert: true
# traefik_origin_cert_content: "{{ vault_traefik_origin_cert }}"
# traefik_origin_key_content: "{{ vault_traefik_origin_key }}"

# Homepage hub role
homepage_enable: false
homepage_stack_root: /opt/homepage
homepage_image: ghcr.io/gethomepage/homepage:latest
homepage_container_name: homepage
homepage_container_port: 3000
homepage_domain: "{{ traefik_domain }}"
homepage_host: "{{ ('hub.' ~ homepage_domain) if (homepage_domain | length > 0) else '' }}"
homepage_network_name: "{{ traefik_network_name }}"
homepage_manage_default_config: true
homepage_title: OpenClaw Hub
homepage_description: Services dashboard behind Traefik + Cloudflare Access

# Example:
# homepage_enable: true
# homepage_domain: akhenda.net
# homepage_host: hub.akhenda.net

# OpenClaw role
openclaw_enable: false
openclaw_install_mode: release
openclaw_repo_ref: main
openclaw_target_dir: /opt/openclaw-ansible
tailscale_authkey: ""
openclaw_manage_bootstrap_policy: true
openclaw_cli_user: "{{ base_admin_user }}"
openclaw_workspace_subpath: ".openclaw/workspace"
openclaw_config_subpath: ".openclaw/openclaw.json"
openclaw_policy_subdir: "bootstrap/openclaw-traefik"
openclaw_policy_hook_paths:
  - "{{ openclaw_policy_subdir }}/AGENTS.md"
  - "{{ openclaw_policy_subdir }}/SOUL.md"
openclaw_policy_domain: "{{ traefik_domain }}"
openclaw_policy_network_name: "{{ traefik_network_name }}"
openclaw_policy_entrypoint: websecure
openclaw_policy_require_tls: true
openclaw_restart_gateway_after_policy_config: false

# Bootstrap playbook optional values
bootstrap_admin_user: ""
bootstrap_admin_ssh_public_key: ""
bootstrap_admin_groups: sudo
