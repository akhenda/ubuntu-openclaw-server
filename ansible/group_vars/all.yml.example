---
# Copy to ansible/group_vars/all.yml (gitignored) and customize.

# Base role
base_timezone: Africa/Nairobi
base_manage_firewall: true
base_install_fail2ban: true
base_enable_unattended_upgrades: true
base_apt_upgrade: dist
base_unattended_auto_reboot: false
base_set_timezone: true
base_ssh_port: "1773"
base_allowed_ssh_ports:
  - "1773"

base_manage_admin_user: true
base_require_admin_ssh_key: true
base_remove_ubuntu_user: true
base_admin_user: "{{ lookup('ansible.builtin.env', 'INFRA_ADMIN_USER') | default('openclaw', true) }}"
base_admin_password: "{{ lookup('ansible.builtin.env', 'INFRA_ADMIN_PASSWORD') | default('', true) }}"
base_admin_password_hash: "{{ lookup('ansible.builtin.env', 'INFRA_ADMIN_PASSWORD_HASH') | default('', true) }}"
base_admin_ssh_public_key: "{{ lookup('ansible.builtin.env', 'INFRA_ADMIN_SSH_PUBLIC_KEY') | default('', true) }}"
base_admin_ssh_public_keys: []
base_admin_groups: sudo
base_fqdn: "{{ lookup('ansible.builtin.env', 'INFRA_FQDN') | default('', true) }}"
base_host_ip: "{{ lookup('ansible.builtin.env', 'INFRA_HOST_IP') | default('', true) }}"
base_configure_motd: true

# Hardening role
hardening_enable_devsec: true
os_ignore_users:
  - ubuntu
  - "{{ base_admin_user }}"

ssh_server_password_login: false
ssh_server_ports:
  - "{{ base_ssh_port }}"
ssh_client_port: "{{ base_ssh_port }}"
ssh_permit_root_login: "no"
ssh_use_dns: false
ssh_max_auth_retries: 2
ssh_allow_tcp_forwarding: "no"
ssh_x11_forwarding: false
ssh_allow_users: "{{ base_admin_user }}"
ssh_print_motd: false
ssh_print_last_log: false
ssh_print_debian_banner: false

# OpenClaw role
openclaw_enable: false
openclaw_install_mode: release
openclaw_repo_ref: main
openclaw_target_dir: /opt/openclaw-ansible
tailscale_authkey: ""

# Bootstrap playbook optional values
bootstrap_admin_user: ""
bootstrap_admin_ssh_public_key: ""
bootstrap_admin_groups: sudo
